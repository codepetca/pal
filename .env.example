# Copy this file to apps/web/.env.local and fill in the values.
# (Next.js reads env files from apps/web/, not the repo root.)
# Never commit .env.local files to the repo.

# Database (Postgres). For local dev, start one with:
#   docker compose up -d postgres
# Must be a POOLED connection string — event ingest holds an interactive
# transaction with a row lock, which HTTP-based serverless drivers cannot do.
DATABASE_URL=postgres://pal:pal@localhost:5433/pal

# Database used by integration tests. Tests truncate tables between cases, so
# this must never point at a database whose contents you care about.
TEST_DATABASE_URL=postgres://pal:pal@localhost:5433/pal_test

# Integration secret used by the dev sandbox to authenticate test events
SANDBOX_INTEGRATION_SECRET=dev-secret-changeme
