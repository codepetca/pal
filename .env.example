# Copy this file to apps/web/.env.local and fill in the values.
# (Next.js reads env files from apps/web/, not the repo root.)
# Never commit .env.local files to the repo.

# Database (Postgres — not needed until Milestone 1 DB work begins)
DATABASE_URL=

# Integration secret used by the dev sandbox to authenticate test events
SANDBOX_INTEGRATION_SECRET=dev-secret-changeme
